# SwiftPM
.build/
# Isolated build dir for full-Xcode `swift test` runs (DEVELOPER_DIR
# override) so its Swift-6.3 artifacts never clobber the CLT .build/ —
# same split sill's scripts/test.sh uses.
.build-xcode/
.swiftpm/
# Package.resolved IS tracked (not ignored): perch is an executable with an
# external dependency (sill), so the lockfile is committed for reproducible
# CI builds + Dependabot version tracking.
*.xcodeproj/
*.xcworkspace/

# macOS
.DS_Store
*.swp

# App bundles produced by local build scripts
*.app/

# Icon generator scratch (scripts/make-icon.sh)
.icon-build/
Perch.iconset/

# Code signing (setup-signing-cert.sh writes the identity name here)
.signing-id

# Logs (local dev)
/tmp/*.log
